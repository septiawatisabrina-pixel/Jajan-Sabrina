<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, maximum-scale=1.0">
  <title>Buyfire • Game Tembak-tembakan</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: #0a0a0a;
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100vh;
      font-family: 'Segoe UI', 'Poppins', system-ui, sans-serif;
      overflow: hidden;
      touch-action: none; /* cegah scroll di mobile saat main */
    }

    #gameContainer {
      position: relative;
      width: 100vw;
      height: 100vh;
      max-width: 100%;
      overflow: hidden;
      background: radial-gradient(circle at 20% 20%, #1a3a2a, #0d1f14);
      cursor: none; /* sembunyikan kursor default, kita pakai crosshair */
    }

    canvas {
      display: block;
      width: 100%;
      height: 100%;
    }

    /* UI overlay */
    .ui-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      pointer-events: none;
      padding: 1rem;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      z-index: 10;
    }

    .game-title {
      font-size: 2.4rem;
      font-weight: 900;
      letter-spacing: 2px;
      background: linear-gradient(180deg, #ff6a3d, #ff2e2e);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      text-shadow: 0 0 20px #ff4400aa;
      filter: drop-shadow(0 4px 6px black);
    }

    .stats-panel {
      background: rgba(10, 10, 10, 0.75);
      backdrop-filter: blur(10px);
      border-radius: 2rem;
      padding: 0.5rem 1.5rem;
      color: white;
      display: flex;
      gap: 2rem;
      font-weight: bold;
      border: 1px solid rgba(255, 100, 40, 0.5);
      box-shadow: 0 8px 20px rgba(0,0,0,0.6);
      pointer-events: none;
    }

    .stat {
      display: flex;
      align-items: center;
      gap: 0.3rem;
    }

    .health-bar-bg {
      width: 100px;
      height: 10px;
      background: #333;
      border-radius: 10px;
      overflow: hidden;
    }

    .health-fill {
      height: 100%;
      width: 100%;
      background: linear-gradient(90deg, #ff4d4d, #ffb347);
      border-radius: 10px;
      transition: width 0.15s ease;
    }

    .ammo-indicator {
      position: absolute;
      bottom: 30px;
      right: 30px;
      background: #0f0f0fdd;
      backdrop-filter: blur(8px);
      color: white;
      font-size: 1.8rem;
      font-weight: 700;
      padding: 0.6rem 1.8rem;
      border-radius: 50px;
      letter-spacing: 2px;
      border: 2px solid #ffb56b;
      box-shadow: 0 0 25px #ff5e00aa;
      z-index: 20;
      pointer-events: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .crosshair {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 20px;
      height: 20px;
      pointer-events: none;
      z-index: 100;
    }

    .crosshair::before,
    .crosshair::after {
      content: '';
      position: absolute;
      background: rgba(255, 255, 255, 0.95);
    }

    .crosshair::before {
      width: 2px;
      height: 20px;
      left: 9px;
      top: 0;
    }

    .crosshair::after {
      width: 20px;
      height: 2px;
      left: 0;
      top: 9px;
    }

    .message-pop {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      color: white;
      font-weight: 900;
      font-size: 2rem;
      text-shadow: 0 0 20px black;
      background: rgba(0,0,0,0.7);
      padding: 1rem 2rem;
      border-radius: 3rem;
      z-index: 200;
      display: none;
    }

    .restart-btn {
      position: absolute;
      bottom: 40px;
      left: 50%;
      transform: translateX(-50%);
      background: #ff5722;
      border: none;
      color: white;
      font-weight: bold;
      font-size: 1.2rem;
      padding: 0.8rem 2.5rem;
      border-radius: 3rem;
      letter-spacing: 1px;
      cursor: pointer;
      z-index: 50;
      pointer-events: auto;
      box-shadow: 0 10px 25px #ff3d00;
      display: none;
      transition: 0.2s;
    }

    .restart-btn:hover {
      background: #ff7849;
      box-shadow: 0 12px 30px #ff5e2e;
    }

    @media (max-width: 600px) {
      .game-title {
        font-size: 1.8rem;
      }
      .ammo-indicator {
        font-size: 1.3rem;
        padding: 0.4rem 1.2rem;
      }
    }
  </style>
</head>
<body>
  <div id="gameContainer">
    <canvas id="gameCanvas"></canvas>
    
    <!-- UI -->
    <div class="ui-overlay">
      <div class="game-title">BUYFIRE</div>
      <div class="stats-panel">
        <div class="stat">❤️ <span id="healthValue">100</span>%</div>
        <div class="stat">🎯 <span id="scoreDisplay">0</span></div>
        <div class="stat">👾 <span id="enemyCount">5</span></div>
      </div>
    </div>

    <div class="ammo-indicator" id="ammoDisplay">
      🔫 <span id="ammoValue">30</span> / <span id="maxAmmo">30</span>
    </div>

    <div class="crosshair" id="crosshair"></div>

    <div class="message-pop" id="messagePop"></div>
    <button class="restart-btn" id="restartButton">↺ MAIN LAGI</button>
  </div>

  <script>
    (function() {
      const canvas = document.getElementById('gameCanvas');
      const ctx = canvas.getContext('2d');

      // UI elements
      const healthValue = document.getElementById('healthValue');
      const scoreDisplay = document.getElementById('scoreDisplay');
      const enemyCountSpan = document.getElementById('enemyCount');
      const ammoValue = document.getElementById('ammoValue');
      const maxAmmoSpan = document.getElementById('maxAmmo');
      const messagePop = document.getElementById('messagePop');
      const restartBtn = document.getElementById('restartButton');

      // Ukuran canvas responsif
      function resizeCanvas() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }
      window.addEventListener('resize', resizeCanvas);
      resizeCanvas();

      // ========== GAME STATE ==========
      const PLAYER_SPEED = 5.5;
      const MOUSE_SENSITIVITY = 0.002;
      
      let player = {
        x: canvas.width / 2,
        y: canvas.height / 2,
        angle: 0,        // sudut pandang (radian)
        health: 100,
        maxHealth: 100
      };

      let bullets = [];
      let enemies = [];
      let score = 0;
      let ammo = 30;
      const MAX_AMMO = 30;
      let gameOver = false;
      let gameWin = false;

      // Kontrol keyboard
      const keys = {
        w: false, a: false, s: false, d: false
      };

      // Mouse
      let mouseDown = false;
      let mouseX = canvas.width/2, mouseY = canvas.height/2;

      // Spawn musuh
      function spawnEnemy(count = 5) {
        enemies = [];
        for (let i = 0; i < count; i++) {
          enemies.push(createEnemy());
        }
      }

      function createEnemy() {
        const side = Math.floor(Math.random() * 4);
        let x, y;
        const pad = 80;
        if (side === 0) { // atas
          x = Math.random() * canvas.width;
          y = -pad;
        } else if (side === 1) { // kanan
          x = canvas.width + pad;
          y = Math.random() * canvas.height;
        } else if (side === 2) { // bawah
          x = Math.random() * canvas.width;
          y = canvas.height + pad;
        } else { // kiri
          x = -pad;
          y = Math.random() * canvas.height;
        }
        return {
          x, y,
          radius: 22,
          health: 35,
          maxHealth: 35,
          speed: 1.2 + Math.random() * 1.3,
          color: `hsl(${Math.floor(Math.random() * 20 + 10)}, 80%, 55%)`,
          id: Math.random()
        };
      }

      // Reset game
      function resetGame() {
        player.health = player.maxHealth;
        player.x = canvas.width/2;
        player.y = canvas.height/2;
        player.angle = 0;
        bullets = [];
        ammo = MAX_AMMO;
        score = 0;
        gameOver = false;
        gameWin = false;
        spawnEnemy(5);
        updateUI();
        messagePop.style.display = 'none';
        restartBtn.style.display = 'none';
      }

      // Cek game over / win
      function checkGameStatus() {
        if (player.health <= 0) {
          gameOver = true;
          player.health = 0;
          messagePop.textContent = '💀 GAME OVER';
          messagePop.style.display = 'block';
          restartBtn.style.display = 'block';
        }
        if (enemies.length === 0 && !gameOver && !gameWin) {
          gameWin = true;
          messagePop.textContent = '🏆 BOOYAH! MENANG!';
          messagePop.style.display = 'block';
          restartBtn.style.display = 'block';
        }
        updateUI();
      }

      // Update UI
      function updateUI() {
        healthValue.textContent = Math.max(0, player.health);
        scoreDisplay.textContent = score;
        enemyCountSpan.textContent = enemies.length;
        ammoValue.textContent = ammo;
        maxAmmoSpan.textContent = MAX_AMMO;
        
        // health bar visual di canvas (digambar terpisah)
      }

      // Tembak
      function shoot() {
        if (gameOver || gameWin) return;
        if (ammo <= 0) {
          // efek klik kosong
          showTemporaryMessage('🔇 KLIK! ammo habis');
          return;
        }
        
        ammo--;
        const bulletSpeed = 18;
        const angle = player.angle;
        bullets.push({
          x: player.x,
          y: player.y,
          vx: Math.cos(angle) * bulletSpeed,
          vy: Math.sin(angle) * bulletSpeed,
          radius: 5,
          damage: 25,
          life: 1
        });
        
        updateUI();
      }

      function showTemporaryMessage(text) {
        const toast = document.createElement('div');
        toast.textContent = text;
        toast.style.position = 'absolute';
        toast.style.bottom = '100px';
        toast.style.left = '50%';
        toast.style.transform = 'translateX(-50%)';
        toast.style.background = '#222';
        toast.style.color = 'white';
        toast.style.padding = '0.5rem 1.5rem';
        toast.style.borderRadius = '30px';
        toast.style.zIndex = '300';
        document.getElementById('gameContainer').appendChild(toast);
        setTimeout(() => toast.remove(), 700);
      }

      // Update posisi player
      function movePlayer() {
        if (gameOver || gameWin) return;
        let moveX = 0, moveY = 0;
        if (keys.w) { moveX += Math.cos(player.angle) * PLAYER_SPEED; moveY += Math.sin(player.angle) * PLAYER_SPEED; }
        if (keys.s) { moveX -= Math.cos(player.angle) * PLAYER_SPEED; moveY -= Math.sin(player.angle) * PLAYER_SPEED; }
        if (keys.a) { moveX += Math.sin(player.angle) * PLAYER_SPEED; moveY -= Math.cos(player.angle) * PLAYER_SPEED; }
        if (keys.d) { moveX -= Math.sin(player.angle) * PLAYER_SPEED; moveY += Math.cos(player.angle) * PLAYER_SPEED; }
        
        player.x = Math.min(Math.max(player.x + moveX, 30), canvas.width - 30);
        player.y = Math.min(Math.max(player.y + moveY, 30), canvas.height - 30);
      }

      // Update musuh bergerak mendekati player
      function updateEnemies() {
        if (gameOver || gameWin) return;
        for (let enemy of enemies) {
          const dx = player.x - enemy.x;
          const dy = player.y - enemy.y;
          const dist = Math.sqrt(dx*dx+dy*dy);
          if (dist > 1) {
            const normX = dx / dist;
            const normY = dy / dist;
            enemy.x += normX * enemy.speed;
            enemy.y += normY * enemy.speed;
          }
          
          // Cek tabrakan dengan player
          if (dist < enemy.radius + 18) {
            player.health -= 0.8; // damage perlahan jika dekat
            if (player.health < 0) player.health = 0;
          }
        }
      }

      // Update peluru & collision
      function updateBullets() {
        bullets = bullets.filter(b => {
          b.x += b.vx;
          b.y += b.vy;
          
          // hilang jika keluar layar
          if (b.x < -20 || b.x > canvas.width+20 || b.y < -20 || b.y > canvas.height+20) {
            return false;
          }
          
          // cek tabrakan dengan musuh
          for (let i = enemies.length-1; i >= 0; i--) {
            const enemy = enemies[i];
            const d = Math.hypot(b.x - enemy.x, b.y - enemy.y);
            if (d < enemy.radius + b.radius) {
              enemy.health -= b.damage;
              if (enemy.health <= 0) {
                enemies.splice(i,1);
                score += 10;
              }
              return false; // peluru hilang setelah kena
            }
          }
          return true;
        });
      }

      // Gambar semua
      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        
        // Grid lantai ala arena
        ctx.strokeStyle = '#2a5230';
        ctx.lineWidth = 0.8;
        const gridSize = 70;
        for (let i = 0; i < canvas.width; i+=gridSize) {
          ctx.beginPath();
          ctx.moveTo(i, 0);
          ctx.lineTo(i, canvas.height);
          ctx.strokeStyle = '#1f3b22';
          ctx.stroke();
        }
        for (let j = 0; j < canvas.height; j+=gridSize) {
          ctx.beginPath();
          ctx.moveTo(0, j);
          ctx.lineTo(canvas.width, j);
          ctx.stroke();
        }
        
        // Gambar musuh
        enemies.forEach(enemy => {
          ctx.save();
          ctx.translate(enemy.x, enemy.y);
          // badan musuh
          ctx.fillStyle = enemy.color;
          ctx.shadowColor = '#ff5500';
          ctx.shadowBlur = 15;
          ctx.beginPath();
          ctx.arc(0, 0, enemy.radius, 0, Math.PI*2);
          ctx.fill();
          ctx.fillStyle = '#111';
          ctx.shadowBlur = 5;
          ctx.beginPath();
          ctx.arc(-6, -5, 4, 0, Math.PI);
          ctx.fill();
          ctx.beginPath();
          ctx.arc(6, -5, 4, 0, Math.PI);
          ctx.fill();
          // health bar musuh
          const healthPercent = enemy.health / enemy.maxHealth;
          ctx.fillStyle = '#222';
          ctx.fillRect(-15, -enemy.radius-10, 30, 5);
          ctx.fillStyle = '#ff4f4f';
          ctx.fillRect(-15, -enemy.radius-10, 30 * healthPercent, 5);
          ctx.restore();
        });

        // Gambar player (dari atas, representasi)
        ctx.save();
        ctx.translate(player.x, player.y);
        ctx.rotate(player.angle);
        ctx.fillStyle = '#3b82f6';
        ctx.shadowColor = '#00a6ff';
        ctx.shadowBlur = 18;
        ctx.beginPath();
        ctx.arc(0, 0, 18, 0, Math.PI*2);
        ctx.fill();
        // senjata
        ctx.fillStyle = '#222';
        ctx.fillRect(10, -4, 22, 8);
        ctx.fillStyle = '#facc15';
        ctx.beginPath();
        ctx.arc(28, 0, 5, 0, 2*Math.PI);
        ctx.fill();
        ctx.restore();

        // Peluru
        bullets.forEach(b => {
          ctx.beginPath();
          ctx.arc(b.x, b.y, b.radius, 0, 2*Math.PI);
          ctx.fillStyle = '#ffdd44';
          ctx.shadowBlur = 12;
          ctx.fill();
        });

        // crosshair sudah di CSS, tambahkan info health bar player
        ctx.fillStyle = '#000000aa';
        ctx.fillRect(20, canvas.height-50, 200, 15);
        ctx.fillStyle = '#22c55e';
        const playerHealthPercent = player.health / player.maxHealth;
        ctx.fillRect(20, canvas.height-50, 200 * playerHealthPercent, 15);
        ctx.fillStyle = 'white';
        ctx.font = 'bold 12px sans-serif';
        ctx.fillText('BUYFIRE', 20, canvas.height-60);
      }

      // Game loop
      function gameLoop() {
        if (!gameOver && !gameWin) {
          movePlayer();
          updateEnemies();
          updateBullets();
          checkGameStatus();
        }
        draw();
        updateUI();
        requestAnimationFrame(gameLoop);
      }

      // Event listeners
      window.addEventListener('keydown', (e) => {
        const key = e.key.toLowerCase();
        if (key === 'w' || key === 'a' || key === 's' || key === 'd') {
          keys[key] = true;
          e.preventDefault();
        }
        // Reload (R)
        if (key === 'r' && !gameOver && !gameWin) {
          ammo = MAX_AMMO;
          updateUI();
          showTemporaryMessage('🔄 Reloaded');
          e.preventDefault();
        }
      });

      window.addEventListener('keyup', (e) => {
        const key = e.key.toLowerCase();
        if (key === 'w' || key === 'a' || key === 's' || key === 'd') {
          keys[key] = false;
          e.preventDefault();
        }
      });

      // Mouse control untuk aim dan shoot
      canvas.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        // Update sudut player berdasarkan posisi mouse relatif terhadap player
        const dx = mouseX - player.x;
        const dy = mouseY - player.y;
        player.angle = Math.atan2(dy, dx);
      });

      canvas.addEventListener('mousedown', (e) => {
        if (e.button === 0) {
          mouseDown = true;
          shoot();
          e.preventDefault();
        }
      });

      canvas.addEventListener('mouseup', (e) => {
        if (e.button === 0) mouseDown = false;
      });

      canvas.addEventListener('contextmenu', e => e.preventDefault());

      // Tembak terus jika mouse ditahan (otomatis)
      setInterval(() => {
        if (mouseDown && !gameOver && !gameWin) {
          shoot();
        }
      }, 180); // fire rate

      // Restart button
      restartBtn.addEventListener('click', () => {
        resetGame();
      });

      // Touch support untuk mobile
      canvas.addEventListener('touchmove', (e) => {
        e.preventDefault();
        const touch = e.touches[0];
        if (!touch) return;
        mouseX = touch.clientX;
        mouseY = touch.clientY;
        const dx = mouseX - player.x;
        const dy = mouseY - player.y;
        player.angle = Math.atan2(dy, dx);
      }, { passive: false });

      canvas.addEventListener('touchstart', (e) => {
        e.preventDefault();
        const touch = e.touches[0];
        if (touch) {
          mouseX = touch.clientX;
          mouseY = touch.clientY;
          player.angle = Math.atan2(mouseY - player.y, mouseX - player.x);
          mouseDown = true;
          shoot();
        }
      });

      canvas.addEventListener('touchend', (e) => {
        e.preventDefault();
        mouseDown = false;
      });

      // Inisialisasi
      resetGame();
      gameLoop();
    })();
  </script>
</body>
</html>
